---
import { getLocaleCopy, type Locale } from '../../lib/i18n';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  locale: Locale;
}

const { headings, locale } = Astro.props;
const copy = getLocaleCopy(locale);
---

<aside class="panel rounded-3xl p-5">
  <p class="mb-4 text-xs uppercase tracking-[0.24em] text-muted">{copy.toc}</p>
  <ul class="space-y-3 text-sm text-muted">
    {headings.map((heading) => (
      <li class:list={{ 'pl-4': heading.depth > 2 }}>
        <a href={`#${heading.slug}`} class="transition hover:text-text">{heading.text}</a>
      </li>
    ))}
  </ul>
</aside>
