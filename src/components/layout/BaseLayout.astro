---
import Header from './Header.astro';
import Footer from './Footer.astro';
import '../../styles/global.css';
import { localeMeta, type Locale } from '../../lib/i18n';

interface Props {
  title: string;
  description?: string;
  locale: Locale;
}

const {
  title,
  description = 'A digital garden optimized for low-bandwidth reading and AI-assisted exploration.',
  locale
} = Astro.props;
const rssUrl = new URL('/rss.xml', Astro.site ?? Astro.url).toString();
---

<!doctype html>
<html lang={localeMeta[locale].lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="alternate" type="application/rss+xml" title="Self Blog RSS" href={rssUrl} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const stored = window.localStorage.getItem('self-blog-theme');
        document.documentElement.dataset.theme = stored === 'soft' ? 'soft' : 'default';
      })();
    </script>
  </head>
  <body class="grid-fade">
    <Header locale={locale} currentPath={Astro.url.pathname} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
