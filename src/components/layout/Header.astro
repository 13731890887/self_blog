---
import MoodOrb from '../islands/MoodOrb.tsx';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getLocaleCopy, localizedPath, type Locale } from '../../lib/i18n';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const copy = getLocaleCopy(locale);
---

<header class="sticky top-0 z-30 border-b border-border/80 bg-bg/85 backdrop-blur">
  <div class="shell flex items-center justify-between gap-6 py-4">
    <a href={localizedPath(locale, '/')} class="font-display text-lg uppercase tracking-[0.18em] text-text">{copy.brand}</a>
    <nav class="hidden items-center gap-5 text-sm text-muted md:flex">
      <a href={localizedPath(locale, '/articles')} class="transition hover:text-text">{copy.navArticles}</a>
      <a href={localizedPath(locale, '/tags/architecture')} class="transition hover:text-text">{copy.navTags}</a>
      <a href={localizedPath(locale, '/admin')} class="transition hover:text-text">{copy.navAdmin}</a>
    </nav>
    <div class="flex items-center gap-3">
      <LanguageSwitcher locale={locale} currentPath={currentPath} />
      <MoodOrb client:idle />
      <a href={localizedPath(locale, '/articles')} class="rounded-full border border-border px-4 py-2 text-sm text-muted transition hover:border-primary hover:text-text">
        {copy.enterGarden}
      </a>
    </div>
  </div>
</header>
