---
import { getLocaleCopy, type Locale } from '../../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = getLocaleCopy(locale);
---

<footer class="border-t border-border/80">
  <div class="shell flex flex-col gap-3 py-8 text-sm text-muted md:flex-row md:items-center md:justify-between">
    <p>{copy.footer}</p>
    <p>{copy.footerSecondary}</p>
  </div>
</footer>
