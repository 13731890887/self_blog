---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import ArticleCard from '../../components/blog/ArticleCard.astro';
import SearchModal from '../../components/islands/SearchModal.tsx';
import { getLocaleCopy, localizedPath } from '../../lib/i18n';

const locale = 'en' as const;
const copy = getLocaleCopy(locale);
const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<BaseLayout title="Self Blog | Digital Garden Noir" locale={locale}>
  <section class="shell py-14 md:py-24">
    <div class="panel rounded-[2rem] p-8 md:p-12">
      <p class="text-xs uppercase tracking-[0.28em] text-secondary">{copy.homeEyebrow}</p>
      <h1 class="mt-5 max-w-4xl font-display text-5xl leading-none tracking-[-0.05em] text-text md:text-7xl">
        {copy.homeTitle}
      </h1>
      <p class="mt-6 max-w-2xl text-base leading-8 text-muted">{copy.homeDescription}</p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <Button href={localizedPath(locale, '/articles')}>{copy.readArticles}</Button>
        <Button href={localizedPath(locale, '/admin')} variant="ghost">{copy.openAdmin}</Button>
        <SearchModal client:idle locale={locale} />
      </div>
    </div>
  </section>

  <section class="shell pb-20">
    <div class="mb-8 flex items-end justify-between gap-4">
      <div>
        <p class="text-xs uppercase tracking-[0.24em] text-muted">{copy.latestNotes}</p>
        <h2 class="mt-3 font-display text-4xl tracking-[-0.04em] text-text">{copy.recentWriting}</h2>
      </div>
      <a href={localizedPath(locale, '/articles')} class="text-sm text-muted transition hover:text-primary">{copy.viewAll}</a>
    </div>
    <div class="grid gap-6 md:grid-cols-3">
      {articles.map((article) => (
        <ArticleCard
          slug={article.slug}
          title={article.data.title}
          description={article.data.description}
          pubDate={article.data.pubDate}
          tags={article.data.tags}
          readingTime={article.data.readingTime}
          locale={locale}
        />
      ))}
    </div>
  </section>
</BaseLayout>
