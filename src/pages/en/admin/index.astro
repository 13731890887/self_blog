---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import Button from '../../../components/ui/Button.astro';
import AdminConsole from '../../../components/islands/AdminConsole.tsx';
import CommunityManager from '../../../components/islands/CommunityManager.tsx';
import { getLocaleCopy, localizedPath } from '../../../lib/i18n';

const locale = 'en' as const;
const copy = getLocaleCopy(locale);
---

<BaseLayout title="Admin | Self Blog" locale={locale}>
  <section class="shell py-16">
    <div class="panel mx-auto max-w-4xl rounded-[2rem] p-8">
      <p class="text-xs uppercase tracking-[0.24em] text-accent-warm">{copy.protectedRoute}</p>
      <h1 class="mt-4 font-display text-5xl tracking-[-0.05em] text-text">{copy.adminTitle}</h1>
      <p class="mt-4 max-w-2xl leading-8 text-muted">{copy.adminLiveDescription}</p>
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        <div class="rounded-3xl border border-border bg-bg/60 p-5">
          <p class="text-sm text-text">{copy.adminFeatureSlots}</p>
          <ul class="mt-3 space-y-2 text-sm text-muted">
            <li>{copy.featureOptimizeTitles}</li>
            <li>{copy.featureGenerateTags}</li>
            <li>{copy.featureReadability}</li>
            <li>{copy.featureMeta}</li>
          </ul>
        </div>
        <div class="rounded-3xl border border-border bg-bg/60 p-5">
          <p class="text-sm text-text">{copy.adminPlannedControls}</p>
          <ul class="mt-3 space-y-2 text-sm text-muted">
            <li>{copy.controlPassword}</li>
            <li>{copy.controlPresets}</li>
            <li>{copy.controlStreaming}</li>
            <li>{copy.controlChecklist}</li>
          </ul>
        </div>
      </div>
      <div class="mt-8">
        <AdminConsole client:load locale={locale} />
      </div>
      <div class="mt-8">
        <CommunityManager client:load locale={locale} />
      </div>
      <div class="mt-10 flex justify-center">
        <Button href={localizedPath(locale, '/')}>{copy.returnHome}</Button>
      </div>
    </div>
  </section>
</BaseLayout>
