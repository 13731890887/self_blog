{
  "name": "self-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && node -e \"const fs=require('fs');fs.mkdirSync('dist',{recursive:true});const cp=(src,dest)=>{const stat=fs.statSync(src);if(stat.isDirectory()){fs.readdirSync(src).forEach(f=>cp(src+'/'+f,dest+'/'+f))}else{fs.copyFileSync(src,dest)}};cp('out','dist')\"",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "next": "^15.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.17",
    "eslint": "^9",
    "eslint-config-next": "^15.1.6",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
