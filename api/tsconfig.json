{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/index.ts",
    "src/db/**/*.ts",
    "src/lib/**/*.ts",
    "src/routes/**/*.ts"
  ]
}
